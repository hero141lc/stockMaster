# 复制为项目根目录下的 .env（与 app 文件夹同级），勿放在 app/ 内以免遗漏
#
# 飞书自建应用（勿将真实密钥提交到仓库）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 事件订阅「Verification Token」（长连接 + HTTP 回调均可能用到）
FEISHU_VERIFICATION_TOKEN=
# 若控制台启用了 Encrypt Key，填写此项；留空则按明文事件处理
FEISHU_ENCRYPT_KEY=

# 事件订阅方式：长连接（推荐，开放平台选「使用长连接接收事件」）
FEISHU_WS_ENABLED=true
# 是否启用 HTTP 回调 POST /feishu/events（选「将事件发送至开发者服务器」时才需要 true）
FEISHU_HTTP_EVENTS_ENABLED=false

# 渠道：feishu | wecom | both（简报/预警推到所选渠道）
IM_PROVIDER=feishu

# ---------- 企业微信（可选）----------
# 智能机器人长连接（OpenClaw/API模式）：填写 Bot ID 与 Secret 即可
WECOM_WS_ENABLED=true
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# 群机器人 Webhook：推送简报/预警（与飞书并行时设 IM_PROVIDER=both）
# 二选一：WECOM_WEBHOOK_KEY=仅 key；或 WECOM_WEBHOOK_URL=完整 URL / 仅 key / 缺 https 的企微域名均可
WECOM_WEBHOOK_KEY=
WECOM_WEBHOOK_URL=

# 自建应用「接收消息」回调（企微内发文字 → 密塔搜索；需公网 HTTPS）
# 应用后台接收消息 URL：https://你的域名/wecom/callback
WECOM_CORP_ID=
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=

# 定时简报与预警推送的目标群 chat_id（机器人需已入群）
FEISHU_CHAT_ID=

# 可选：仅推送用的 Webhook（与机器人 API 二选一或并存时注意去重）
FEISHU_WEBHOOK_URL=

# 密塔 API
METASO_API_KEY=
METASO_BASE_URL=https://metaso.cn/api/v1/search

# 时区（定时任务）
TZ=Asia/Shanghai

# 每日简报触发时刻，逗号分隔 HH:MM（24 小时制）
DIGEST_TIMES=09:30,12:30,15:30,21:00

# 简报用的搜索主题，JSON 数组字符串，每项为密塔 q
DIGEST_QUERIES=["A股 宏观 流动性 今日","港股 美股 隔夜 期货","央行 发改委 证监会 要闻"]

# 预警：逗号分隔关键词（会组合进搜索 q，命中即推）
ALERT_KEYWORDS=熔断,停牌,重大资产重组,立案调查,业绩暴雷,ST,退市风险,战争,地缘,美联储,加息,降准

# 预警轮询间隔（分钟）
ALERT_INTERVAL_MINUTES=15

# 单次密塔返回条数
METASO_SEARCH_SIZE=10

# 交互回复：rag=金融分析师 Agent（自主多轮密塔检索 + 综合）；search=仅列出密塔条目（旧版）
REPLY_MODE=rag
# OpenAI 兼容接口（可填代理或国内兼容网关），需与 LLM_MODEL 匹配
# RAG/分析师模式必须使用支持 tools/function calling 的模型，例如：
#   gpt-4o-mini / gpt-4o（OpenAI）
#   deepseek-chat（DeepSeek，LLM_API_BASE=https://api.deepseek.com/v1）
#   qwen-plus / qwen-max（阿里百炼，OpenAI 兼容网关）
#   doubao-1-5-pro-32k（火山方舟，OpenAI 兼容网关）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=90
# 分析师 Agent：最多工具调用轮数（每轮 LLM 可决定是否再次调用 metaso_search）
LLM_MAX_TOOL_CALLS=4
# 生成温度（金融分析建议 0.1~0.3，避免发散）
LLM_TEMPERATURE=0.2
# 分析师人格：当前支持 cn_sellside（A 股/港股/美股卖方研究员风格）
ANALYST_PERSONA=cn_sellside
# 时效性控制：仅优先使用最近 N 天资料；strict=true 时资料太旧会显式拒绝下高置信结论
ANALYST_FRESHNESS_DAYS=120
ANALYST_STRICT_FRESHNESS=true

# SQLite 路径
DATABASE_PATH=./data/app.db

# 服务
HOST=0.0.0.0
PORT=8000
